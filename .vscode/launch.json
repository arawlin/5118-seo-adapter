      "name": "Debug 5118 Longtail Live",
      "type": "node",
      "request": "launch",
      "cwd": "${workspaceFolder}",
      "runtimeExecutable": "node",
      "runtimeArgs": [
        "scripts/test-live-gate.mjs",
        "--tool",
        "longtail",
        "--keyword",
        "比特币",
        "--pageIndex",
        "1",
        "--pageSize",
        "10",
        "--verbose"
      ],
      "env": {
        "API_5118_LONGTAIL_V2": "${input:apiKey5118Longtail}"
      },
      "console": "integratedTerminal",
      "skipFiles": ["<node_internals>/**"]
